{
  "name": "@hpcc-js/wasm-root",
  "private": true,
  "version": "4.6.1",
  "description": "hpcc-js - WASM Libraries",
  "keywords": [
    "graphviz",
    "typescript",
    "webassembly",
    "wasm",
    "dot",
    "zstd",
    "graphviz-dot",
    "zstandard",
    "expat",
    "base91",
    "expat-xml-parser",
    "webassemby"
  ],
  "type": "module",
  "workspaces": [
    "packages/*",
    "tests/bundlers"
  ],
  "scripts": {
    "install-emsdk": "run-script-os",
    "install-emsdk:default": "./scripts/cpp-install-emsdk.sh",
    "install-emsdk:win32": "wsl -e ./scripts/cpp-install-emsdk.sh",
    "install-vcpkg": "run-script-os",
    "install-vcpkg:default": "./scripts/cpp-install-vcpkg.sh",
    "install-vcpkg:win32": "wsl -e ./scripts/cpp-install-vcpkg.sh",
    "install-playright": "npx playwright install",
    "install-playright-with-deps": "npx playwright install --with-deps",
    "install-bundler-deps": "./scripts/install-bundler-deps.sh",
    "install-build-deps": "run-s install-emsdk install-vcpkg install-playright install-bundler-deps",
    "uninstall-build-deps": "rimraf ./emsdk ./vcpkg ./src-expat ./src-vcpkg ./wasi-sdk ./wit-bindgen",
    "uninstall": "rimraf --glob ./node_modules ./packages/**/node_modules ./package-lock.json",
    "clean-build": "rimraf --glob .nyc_output bin build coverage output-* tmp vcpkg/vcpkg .nx",
    "clean-vcpkg": "rimraf --glob vcpkg/buildtrees vcpkg/packages vcpkg/installed vcpkg/downloads",
    "clean-docs": "rimraf .vitepress/dist .vitepress/cache docs/base91 docs/duckdb docs/expat docs/graphviz docs/llama docs/zstd",
    "clean-root": "run-p clean-build clean-docs",
    "clean": "lerna run clean",
    "clean-all": "run-p clean clean-root clean-vcpkg",
    "copy-res": "cp ./docs/*.png ./.vitepress/dist",
    "build-asm": "asc ./src-asm/index.ts --target release",
    "gen-docs": "typedoc",
    "gen-docs-watch": "typedoc --watch",
    "build-cpp": "run-script-os",
    "build-cpp:default": "./scripts/cpp-build.sh",
    "build-cpp:win32": "wsl -e ./scripts/cpp-build.sh",
    "build-cpp-watch": "chokidar 'packages/*/src-cpp/**/*' -c 'npm run build-cpp'",
    "build-types-watch": "lerna run build-types-watch",
    "build-ts-dev": "lerna run build-ts-dev",
    "build-docs-vitepress": "vitepress build .",
    "build-docs": "run-s gen-docs build-docs-vitepress copy-res",
    "build-docs-watch": "vitepress dev .",
    "build-docker-image": "docker build --rm --progress plain -f \"./docker/ubuntu-dev.dockerfile\" -t hpcc-js-wasm-build:latest \".\"",
    "build-docker-wasm": "docker run --rm -it hpcc-js-wasm-build:latest \"npm run build && npm run test\"",
    "build-docker": "run-s build-docker-image build-docker-wasm",
    "build-ws": "lerna run build",
    "build-dev": "lerna run build-dev",
    "build-watch": "lerna run bundle-watch",
    "build": "run-s build-cpp build-ws",
    "git-push": "git push --follow-tags upstream trunk",
    "serve-docs": "vitepress serve .",
    "serve": "npx http-server",
    "lint-skypack": "lerna run lint-skypack",
    "lint": "lerna run lint",
    "lint-fix": "npm run lint -- --fix",
    "test-browser": "vitest run --project browser",
    "test-node": "vitest run --project node",
    "test": "lerna run test",
    "test-bundlers": "npm run test --workspace=tests/bundlers",
    "test-bundlers-script": "./scripts/test-bundlers.sh",
    "test-bundlers-webpack": "npm run test:webpack --workspace=tests/bundlers",
    "test-bundlers-esbuild": "npm run test:esbuild --workspace=tests/bundlers",
    "test-bundlers-rollup": "npm run test:rollup --workspace=tests/bundlers",
    "test-all": "npm run test && npm run test-bundlers",
    "coverage": "lerna run coverage",
    "publish": "lerna publish from-package -y",
    "purge-jsdelivr": "node ./utils/purge-jsdelivr.js",
    "update-root": "npx -y npm-check-updates -u -t minor",
    "update": "npm run update-root && lerna run update",
    "update-major-root": "npx -y npm-check-updates -u",
    "update-major": "npm run update-major-root && lerna run update-major"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/emscripten": "1.41.5",
    "@types/node": "25.2.0",
    "@types/yargs": "17.0.35",
    "@typescript-eslint/parser": "8.54.0",
    "@vitest/browser": "4.0.18",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-istanbul": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "assemblyscript": "0.28.9",
    "chokidar-cli": "3.0.0",
    "eslint": "9.39.2",
    "globals": "17.3.0",
    "happy-dom": "20.5.0",
    "lerna": "9.0.3",
    "npm-run-all": "4.1.5",
    "playwright": "1.58.1",
    "release-please": "17.2.0",
    "rimraf": "6.1.2",
    "run-script-os": "1.1.6",
    "tslib": "2.8.1",
    "typedoc": "0.28.16",
    "typedoc-plugin-markdown": "4.9.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vitepress": "1.6.4",
    "vitest": "4.0.18"
  },
  "c8": {
    "exclude-after-remap": []
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hpcc-systems/hpcc-js-wasm.git"
  },
  "author": "Gordon Smith <gordonjsmith@gmail.com>",
  "contributors": [],
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/hpcc-systems/hpcc-js-wasm/issues"
  },
  "homepage": "https://hpcc-systems.github.io/hpcc-js-wasm/"
}