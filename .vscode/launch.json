{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "test-node",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runtimeArgs": [
                "run-script",
                "test-node"
            ],
            "runtimeExecutable": "npm",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "outFiles": [
                "${workspaceFolder}/packages/**/*.js",
                "${workspaceFolder}/packages/**/*.c",
                "!**/node_modules/**"
            ],
        },
        {
            "name": "index-browser",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:8080/index.html",
            "webRoot": "${workspaceRoot}",
            "sourceMapPathOverrides": {
                "webpack:///./*": "${workspaceRoot}/*",
                "webpack:///*": "/*"
            },
        },
        {
            "name": "file:///index.html",
            "type": "msedge",
            "request": "launch",
            "url": "./index.html",
            "runtimeArgs": [],
            "webRoot": "${workspaceRoot}"
        },
        {
            "name": "http:///index.html",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:8080/index.html",
            "webRoot": "${workspaceRoot}"
        },
        {
            "name": "hw-graphviz.html",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:8080/hw-graphviz.html",
            "webRoot": "${workspaceRoot}"
        },
        {
            "name": "hw-zstd.html",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:8080/hw-zstd.html",
            "webRoot": "${workspaceRoot}"
        },
        {
            "name": "hw-base91.html",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:8080/hw-base91.html",
            "webRoot": "${workspaceRoot}"
        },
        {
            "name": "sfx-wasm",
            "request": "launch",
            "runtimeArgs": [
                "run-script",
                "gen-sfx-graphviz"
            ],
            "runtimeExecutable": "npm",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "test-browser",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:8080/test.html",
            "webRoot": "${workspaceRoot}",
            "sourceMapPathOverrides": {
                "webpack:///./*": "${workspaceRoot}/*",
                "webpack:///*": "/*"
            },
        },
        {
            "name": "esbuild",
            "type": "node",
            "program": "${workspaceFolder}/esbuild.mjs",
            "request": "launch",
            "args": [],
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "CLI",
            "program": "${workspaceFolder}/bin/dot-wasm.js",
            "request": "launch",
            "args": [
                "-K neato",
                "-n 2",
                "./src-ts/__tests__/simple.dot"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "CLI Version",
            "program": "${workspaceFolder}/bin/dot-wasm.js",
            "request": "launch",
            "args": [
                "-v"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        }
    ]
}